e.values[0]), consolidated=True)\n    return drop_all_bounds(ds)\n\ndef open_delayed(df):\n    return dask.delayed(open_dset)(df)\n\nfrom collections import defaultdict\ndsets = defaultdict(dict)\n\nfor group, df in col_subset.df.groupby(by=['source_id', 'experiment_id']):\n    dsets[group[0]][group[1]] = open_delayed(df)","key":"BLilGx0u4p"},{"type":"output","id":"jBQ4wyFmeFs6ntdYKR19p","data":[],"key":"F0DsTAwYJy"}],"key":"s1c2So0Q4a"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"dsets_ = dask.compute(dict(dsets))[0]","key":"xserXgbsWR"},{"type":"output","id":"y1kPTXJNmJ4Zn9a6ModOu","data":[],"key":"H9JCyOeQy9"}],"key":"Kq77asyJah"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Calculate global means:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"yBcnqiBZ6b"}],"key":"n1kddeUJ94"}],"key":"RK9zZyPRDu"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def get_lat_name(ds):\n    for lat_name in ['lat', 'latitude']:\n        if lat_name in ds.coords:\n            return lat_name\n    raise RuntimeError(\"Couldn't find a latitude coordinate\")\n\ndef global_mean(ds):\n    lat = ds[get_lat_name(ds)]\n    weight = np.cos(np.deg2rad(lat))\n    weight /= weight.mean()\n    other_dims = set(ds.dims) - {'time'}\n    return (ds * weight).mean(other_dims)","key":"dls0pdkrDW"},{"type":"output","id":"mZghS_v5Skrv3v0TJS8i8","data":[],"key":"diKLeF2I01"}],"key":"HyjKPAI6SH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"expt_da = xr.DataArray(expts, dims='experiment_id', name='experiment_id',\n                       coords={'experiment_id': expts})\n\ndsets_aligned = {}\n\nfor k, v in tqdm(dsets_.items()):\n    expt_dsets = v.values()\n    if any([d is None for d in expt_dsets]):\n        print(f\"Missing experiment for {k}\")\n        continue\n\n    for ds in expt_dsets:\n        ds.coords['year'] = ds.time.dt.year\n\n    # workaround for\n    # https://github.com/pydata/xarray/issues/2237#issuecomment-620961663\n    dsets_ann_mean = [v[expt].pipe(global_mean)\n                             .swap_dims({'time': 'year'})\n                             .drop('time')\n                             .coarsen(year=12).mean()\n                      for expt in expts]\n\n    # align everything with the 4xCO2 experiment\n    dsets_aligned[k] = xr.concat(dsets_ann_mean, join='outer',\n                                 dim=expt_da)","key":"RRYWUeBrM0"},{"type":"output","id":"3uZBWf4XFe1GzO_zXCIga","data":[],"key":"JxMi2UOIBG"}],"key":"ihkf6hX3We"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"dsets_aligned_ = dask.compute(dsets_aligned)[0]","key":"md8Bb6TPIe"},{"type":"output","id":"FfL5zIxknDAN8X2POqGpl","data":[],"key":"zslhAyzkCA"}],"key":"TEcB9tRZYi"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"source_ids = list(dsets_aligned_.keys())\nsource_da = xr.DataArray(source_ids, dims='source_id', name='source_id',\n                         coords={'source_id': source_ids})\n\nbig_ds = xr.concat([ds.reset_coords(drop=True)\n                    for ds in dsets_aligned_.values()],\n                    dim=source_da)\n\nbig_ds","key":"q6tsr2mUiD"},{"type":"output","id":"PLQlXWn_FwXiGLzEKEFKD","data":[],"key":"OUUxLeguAn"}],"key":"HWYSvqEVcV"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"df_all = big_ds.sel(year=slice(1900, 2100)).to_dataframe().reset_index()\ndf_all.head()","key":"Tf0Kgv409i"},{"type":"output","id":"UPOlboc5V8sYOtff_-0ud","data":[],"key":"lGYfMA7Knx"}],"key":"IZWoUagaon"},{"type":"block","kind":"notebook-code"