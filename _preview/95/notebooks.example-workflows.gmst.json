return dask.delayed(open_dset)(df)\n\nfrom collections import defaultdict\ndsets = defaultdict(dict)\n\nfor group, df in col_subset.df.groupby(by=['source_id', 'experiment_id']):\n    dsets[group[0]][group[1]] = open_delayed(df)","key":"MruoA2eWoi"},{"type":"outputs","id":"-wDKeJsV99Ck0Wqg9lgp3","children":[],"key":"ZRm8EZTqbV"}],"key":"Tx5rTLGfP3"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"dsets_ = dask.compute(dict(dsets))[0]","key":"gN4cBx4HZj"},{"type":"outputs","id":"3gikeVBoXLLjq7jrahj0u","children":[],"key":"stTUzj4mPc"}],"key":"z3VH9QuMlx"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Calculate global means:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"WtdCRZ1Mx0"}],"key":"lhEFUT23MG"}],"key":"ATaPWbQOYP"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def get_lat_name(ds):\n    for lat_name in ['lat', 'latitude']:\n        if lat_name in ds.coords:\n            return lat_name\n    raise RuntimeError(\"Couldn't find a latitude coordinate\")\n\ndef global_mean(ds):\n    lat = ds[get_lat_name(ds)]\n    weight = np.cos(np.deg2rad(lat))\n    weight /= weight.mean()\n    other_dims = set(ds.dims) - {'time'}\n    return (ds * weight).mean(other_dims)","key":"RU9matOtHz"},{"type":"outputs","id":"TgnqheZ_Oi72duY8_ywUA","children":[],"key":"qao4ilwCEU"}],"key":"eTpTYk807f"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"expt_da = xr.DataArray(expts, dims='experiment_id', name='experiment_id',\n                       coords={'experiment_id': expts})\n\ndsets_aligned = {}\n\nfor k, v in tqdm(dsets_.items()):\n    expt_dsets = v.values()\n    if any([d is None for d in expt_dsets]):\n        print(f\"Missing experiment for {k}\")\n        continue\n\n    for ds in expt_dsets:\n        ds.coords['year'] = ds.time.dt.year\n\n    # workaround for\n    # https://github.com/pydata/xarray/issues/2237#issuecomment-620961663\n    dsets_ann_mean = [v[expt].pipe(global_mean)\n                             .swap_dims({'time': 'year'})\n                             .drop_vars('time')\n                             .coarsen(year=12).mean()\n                      for expt in expts]\n\n    # align everything with the 4xCO2 experiment\n    dsets_aligned[k] = xr.concat(dsets_ann_mean, join='outer',\n                                 dim=expt_da)","key":"xLQfiCJr2s"},{"type":"outputs","id":"VYWR0_I-RcfKh5TILDMbx","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"  0%|          | 0/34 [00:00<?, ?it/s]","content_type":"text/plain"},"application/vnd.jupyter.widget-view+json":{"content":"{\"version_major\":2,\"version_minor\":0,\"model_id\":\"43e66e1d4d404f998385bc3bb1ad8739\"}","content_type":"application/vnd.jupyter.widget-view+json"}}},"key":"DDmd3GfHJM"}],"key":"rbWhPm7pkX"}],"key":"hCmYUGPrgw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"dsets_aligned_ = dask.compute(dsets_aligned)[0]","key":"ZZxnVQJSO8"},{"type":"outputs","id":"eBaYBJ-OkJZ7ZoHJnO-Bp","children":[],"key":"NEAlCdz0ev"}],"key":"uObsxSSR2y"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"source_ids = list(dsets_aligned_.keys())\nsource_da = xr.DataArray(source_ids, dims='source_id', name='source_id',\n                         coords={'source_id': source_ids})\n\nbig_ds = xr.concat([ds.reset_coords(drop=True)\n                    for ds in dsets_aligned_.values()],\n                    dim=source_da)\n\nbig_ds","key":"OBF4NrHbd4"},{"type":"outputs","id":"m_WimC3CaG2B9CX91Del_","children":[{"type":"output","children":[],"jupy