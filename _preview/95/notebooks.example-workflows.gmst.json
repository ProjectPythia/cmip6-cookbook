me ) or ('_bnds') in vname]\n    return ds.drop_vars(drop_vars)\n\ndef open_dset(df):\n    assert len(df) == 1\n    ds = xr.open_zarr(fsspec.get_mapper(df.zstore.values[0], token='anon'), \n                      consolidated=True, \n                      decode_times=time_coder)\n    return drop_all_bounds(ds)\n\ndef open_delayed(df):\n    return dask.delayed(open_dset)(df)\n\nfrom collections import defaultdict\ndsets = defaultdict(dict)\n\nfor group, df in col_subset.df.groupby(by=['source_id', 'experiment_id']):\n    dsets[group[0]][group[1]] = open_delayed(df)","key":"Uhr161uTaH"},{"type":"outputs","id":"cLRX_S9CPTcdrQvUEsjb8","children":[],"key":"jfRrbBqiNv"}],"key":"jdwfH26otW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"dsets_ = dask.compute(dict(dsets))[0]","key":"EF6EnXB6dV"},{"type":"outputs","id":"CrdmvF30U0Ap4J-9F8i3Q","children":[],"key":"he2kasX0zw"}],"key":"Gl60COvZmP"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Calculate global means:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nwaFzmlcj5"}],"key":"Xenzp9L5WD"}],"key":"rxPNfNLUqj"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def get_lat_name(ds):\n    for lat_name in ['lat', 'latitude']:\n        if lat_name in ds.coords:\n            return lat_name\n    raise RuntimeError(\"Couldn't find a latitude coordinate\")\n\ndef global_mean(ds):\n    lat = ds[get_lat_name(ds)]\n    weight = np.cos(np.deg2rad(lat))\n    weight /= weight.mean()\n    other_dims = set(ds.dims) - {'time'}\n    return (ds * weight).mean(other_dims)","key":"UK8Dwv0YDg"},{"type":"outputs","id":"VCsSXVaTju2PZPdNP8To0","children":[],"key":"Ex6Lb919v5"}],"key":"znKaq1kngK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"expt_da = xr.DataArray(expts, dims='experiment_id', name='experiment_id',\n                       coords={'experiment_id': expts})\n\ndsets_aligned = {}\n\nfor k, v in tqdm(dsets_.items()):\n    expt_dsets = v.values()\n    if any([d is None for d in expt_dsets]):\n        print(f\"Missing experiment for {k}\")\n        continue\n\n    for ds in expt_dsets:\n        ds.coords['year'] = ds.time.dt.year\n\n    # workaround for\n    # https://github.com/pydata/xarray/issues/2237#issuecomment-620961663\n    dsets_ann_mean = [v[expt].pipe(global_mean)\n                             .swap_dims({'time': 'year'})\n                             .drop_vars('time')\n                             .coarsen(year=12).mean()\n                      for expt in expts]\n\n    # align everything with the 4xCO2 experiment\n    dsets_aligned[k] = xr.concat(dsets_ann_mean, join='outer',\n                                 dim=expt_da)","key":"TG8GCVkztp"},{"type":"outputs","id":"oFRCqIjK1S3QflUm-iuMv","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"  0%|          | 0/34 [00:00<?, ?it/s]","content_type":"text/plain"},"application/vnd.jupyter.widget-view+json":{"content":"{\"version_major\":2,\"version_minor\":0,\"model_id\":\"81e0b4c625d04cf597c48a29c68a273c\"}","content_type":"application/vnd.jupyter.widget-view+json"}}},"key":"gSumNedUdq"}],"key":"KiZAmQiSip"}],"key":"wfEhBHrzHR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"dsets_aligned_ = dask.compute(dsets_aligned)[0]","key":"bLJvtbmmwl"},{"type":"outputs","id":"E3WbYf9lLwhdLpiVafG3k","children":[],"key":"Zxgayfwhv3"}],"key":"dREOIuXnN4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"source_ids = list(dsets_aligned_.keys())\nsource_da = xr.DataArray(source_ids, dims='source_id', name='source_id',\n                         coords={'source_id': source_ids})\n\nbig_ds = xr.concat([ds.reset_coords(drop=True)\n                    for ds in dsets_aligned_.values()],\n                    dim=source_da)\n\nbig_ds","key":"l8IkuXkksP"},{"type":"outputs","id":"jQ6dwuRjrQGFCrsMruBoL","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/tmp/ipykernel_4401/2886188115.py:5: FutureWarning: In a future version of xarray the default value for join will change from join='outer' to join='exact'. This change will result in the following ValueError: cannot be aligned with join='exact' because index/labels/sizes are not equal along these coordinates (dimensions): 'year' ('year',) The recommendation is to set join explicitly for this case.\n  big_ds = xr.concat([ds.reset_coords(drop=True)\n"},"key":"GIkFeTfBhu"},{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":10,"metadata":{},"data":{"text/plain":{"content":"<xarray.Dataset> Size: 374kB\nDimensions:        (source_id: 34, experiment_id: 3, year: 451)\nCoordinates:\n  * source_id      (source_id) <U16 2kB 'ACCESS-CM2' ... 'TaiESM1'\n  * experiment_id  (experiment_id) <U10 120B 'historical' 'ssp245' 'ssp585'\n  * year           (year) float64 4kB 1.85e+03 1.851e+03 ... 2.299e+03 2.3e+03\nData variables:\n    tas            (source_id, experiment_id, year) float64 368kB 287.0 ... nan\nAttributes: (12/53)\n    Conventions:            CF-1.7 CMIP-6.2\n    activity_id:            CMIP\n    branch_method:          standard\n    branch_time_in_child:   0.0\n    branch_time_in_parent:  0.0\n    cmor_version:           3.4.0\n    ...                     ...\n    version:                v20191108\n    axis:                   Y\n    bounds:                 lat_bnds\n    long_name:              Latitude\n    standard_name:          latitude\n    units:                  degrees_north","content_type":"text/plain"},"text/html":{"conte